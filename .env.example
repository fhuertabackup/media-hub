OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_TRANSCRIBE_MODEL=mistralai/voxtral-small-24b-2507
OPENROUTER_ENRICH_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_PHOTO_TITLE_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_OCR_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
OPENROUTER_OCR_FALLBACK_MODELS=google/gemma-3-12b-it:free,nvidia/nemotron-nano-12b-v2-vl:free
TRANSCRIBE_POSTPROCESS=false
OPENROUTER_POSTPROCESS_MODEL=google/gemini-2.0-flash-lite-001
TRANSCRIBE_HINTS=
AUDIO_AI_ENABLED=false
