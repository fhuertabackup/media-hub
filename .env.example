# URL visible from Expo app.
# Android emulator uses: http://10.0.2.2:4001
# iOS simulator can use: http://localhost:4001
# Physical device must use your machine LAN IP.
EXPO_PUBLIC_TRANSCRIBE_API_URL=http://localhost:4001
EXPO_PUBLIC_AUDIO_AI_ENABLED=false
